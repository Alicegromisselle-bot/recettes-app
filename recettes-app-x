<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CookBook</title>
<style>
body {
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    background: linear-gradient(135deg, #f5f1eb, #e8dfd5);
    margin: 0;
    padding: 20px;
}

h1 {
    text-align: center;
    color: #5e4b3c;
    margin-bottom: 10px;
}

.container {
    max-width: 800px;
    margin: auto;
}

.card {
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(10px);
    padding: 20px;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    margin-bottom: 20px;
}

input, textarea, select {
    width: 100%;
    padding: 10px;
    margin-top: 8px;
    border-radius: 10px;
    border: none;
    background: white;
}

button {
    margin-top: 10px;
    padding: 10px;
    border-radius: 12px;
    border: none;
    background: #c6a98f;
    color: white;
    font-weight: bold;
    cursor: pointer;
}

button:hover {
    background: #a8886e;
}

.recipe {
    background: white;
    padding: 15px;
    border-radius: 15px;
    margin-top: 15px;
}

.badge {
    display: inline-block;
    padding: 4px 8px;
    border-radius: 8px;
    background: #e8dfd5;
    font-size: 12px;
    margin-right: 5px;
}

.search {
    margin-bottom: 15px;
}
</style>
</head>
<body>

<div class="container">
    <h1>🍳 CookBook</h1>

    <div class="card">
        <input type="text" id="title" placeholder="Nom de la recette">
        <input type="text" id="time" placeholder="Temps (ex: 30 min)">
        
        <select id="category">
            <option value="">Choisir une catégorie</option>
            <option>Dessert</option>
            <option>Plat</option>
            <option>Entrée</option>
            <option>Healthy</option>
        </select>

        <h3>Ingrédients</h3>
        <div id="ingredients"></div>
        <button onclick="addIngredient()">+ Ajouter ingrédient</button>

        <h3>Étapes</h3>
        <textarea id="steps" rows="4" placeholder="Décris les étapes..."></textarea>

        <button onclick="addRecipe()">Ajouter la recette</button>
    </div>

    <input class="search" type="text" id="search" placeholder="🔍 Rechercher..." oninput="displayRecipes()">

    <div id="recipes"></div>
</div>

<script>
let recipes = JSON.parse(localStorage.getItem("recipes")) || [];

function save() {
    localStorage.setItem("recipes", JSON.stringify(recipes));
}

function addIngredient() {
    const div = document.createElement("div");
    div.innerHTML = '<input type="text" placeholder="Ingrédient">';
    document.getElementById("ingredients").appendChild(div);
}

function addRecipe() {
    const title = document.getElementById("title").value;
    const time = document.getElementById("time").value;
    const category = document.getElementById("category").value;
    const steps = document.getElementById("steps").value;

    const ingredientInputs = document.querySelectorAll("#ingredients input");
    const ingredients = Array.from(ingredientInputs).map(i => i.value).filter(i => i);

    if (!title) return;

    recipes.push({ title, time, category, ingredients, steps });
    save();
    displayRecipes();
    document.querySelector(".card").reset?.();
    location.reload();
}

function deleteRecipe(index) {
    recipes.splice(index,1);
    save();
    displayRecipes();
}

function displayRecipes() {
    const container = document.getElementById("recipes");
    const search = document.getElementById("search").value.toLowerCase();
    container.innerHTML = "";

    recipes
    .filter(r => r.title.toLowerCase().includes(search))
    .forEach((r,index) => {
        container.innerHTML += `
            <div class="recipe">
                <h2>${r.title}</h2>
                <span class="badge">${r.time}</span>
                <span class="badge">${r.category}</span>
                <h4>Ingrédients :</h4>
                <ul>${r.ingredients.map(i=>`<li>${i}</li>`).join("")}</ul>
                <h4>Étapes :</h4>
                <p>${r.steps}</p>
                <button onclick="deleteRecipe(${index})">Supprimer</button>
            </div>
        `;
    });
}

displayRecipes();
</script>

</body>
</html>
